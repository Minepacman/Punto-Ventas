<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!--
    inventario.fxml  –  Gestión de Inventario (F4)
    Controlador: InventarioController.java

    Cinco vistas que se intercambian en el StackPane:
      vistaAgregar       → agregar stock a un producto (default)
      vistaTabla         → tabla completa de productos con stock
      vistaReporte       → reporte de inventario
      vistaMovimientos   → historial de movimientos con filtro de fechas
      vistaImportar      → importar productos desde CSV
-->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="me.eliassanchezfernandez.puntodeventa.controller.InventarioController">

    <!-- ══════════════════════════════════════════════════════════
         VISTA 1 – AGREGAR INVENTARIO  (visible por defecto)
    ══════════════════════════════════════════════════════════ -->
    <BorderPane fx:id="vistaAgregar">

        <top>
            <HBox styleClass="section-toolbar" spacing="8" alignment="CENTER_LEFT">
                <padding><Insets topRightBottomLeft="10"/></padding>
                <Button text="➕ Agregar Stock"          styleClass="button-success"
                        onAction="#onMostrarAgregar"/>
                <Button text="📋 Ver Inventario"
                        onAction="#onMostrarTabla"/>
                <Separator orientation="VERTICAL"/>
                <Button text="📊 Reporte"                onAction="#onMostrarReporte"/>
                <Button text="🕓 Movimientos"            onAction="#onMostrarMovimientos"/>
                <Button text="📥 Importar CSV"           onAction="#onMostrarImportar"/>
            </HBox>
        </top>

        <center>
            <ScrollPane fitToWidth="true">
                <VBox spacing="16" maxWidth="600" alignment="TOP_CENTER">
                    <padding><Insets top="24" right="40" bottom="24" left="40"/></padding>

                    <Label text="AGREGAR AL INVENTARIO" styleClass="form-section-title"/>
                    <Separator/>

                    <!-- Código -->
                    <VBox spacing="4">
                        <Label text="Código del Producto" styleClass="field-label"/>
                        <HBox spacing="8">
                            <TextField fx:id="txtCodigo"
                                       promptText="Escanea o escribe el código"
                                       HBox.hgrow="ALWAYS"
                                       onAction="#onBuscarProducto"/>
                            <Button text="🔍 Buscar" onAction="#onBuscarProducto"/>
                        </HBox>
                        <!-- Aviso producto no encontrado -->
                        <Label fx:id="lblNoEncontrado"
                               text="⚠ Producto no encontrado."
                               visible="false" managed="false"
                               style="-fx-text-fill:#C0392B;-fx-font-size:11"/>
                    </VBox>

                    <!-- Info del producto encontrado -->
                    <VBox fx:id="panelInfoProducto"
                          spacing="10" visible="false" managed="false"
                          style="-fx-background-color:-color-bg-subtle;
                                 -fx-background-radius:8;-fx-padding:14;">

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Descripción:" styleClass="field-label" minWidth="130"/>
                            <Label fx:id="lblDescripcion" text="—"
                                   style="-fx-font-weight:bold"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Departamento:" styleClass="field-label" minWidth="130"/>
                            <Label fx:id="lblDepartamento" text="—"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Stock actual:" styleClass="field-label" minWidth="130"/>
                            <Label fx:id="lblStockActual" text="0"
                                   style="-fx-font-size:18px;-fx-font-weight:bold;
                                          -fx-text-fill:-color-success-fg"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Stock mínimo:" styleClass="field-label" minWidth="130"/>
                            <Label fx:id="lblStockMinimo" text="0"/>
                        </HBox>

                        <Separator/>

                        <VBox spacing="4">
                            <Label text="Cantidad a Agregar *" styleClass="field-label"/>
                            <TextField fx:id="txtCantidad" promptText="0"
                                       onAction="#onAgregarCantidad"/>
                            <Label fx:id="lblErrorCantidad"
                                   text="⚠ Ingresa una cantidad mayor a 0."
                                   visible="false" managed="false"
                                   style="-fx-text-fill:#C0392B;-fx-font-size:11"/>
                        </VBox>

                        <VBox spacing="4">
                            <Label text="Nota (opcional)" styleClass="field-label"/>
                            <TextField fx:id="txtNota" promptText="Ej: Compra a proveedor..."/>
                        </VBox>

                        <Button text="✅ Agregar al Inventario"
                                onAction="#onAgregarCantidad"
                                styleClass="button-success"
                                maxWidth="Infinity" prefHeight="38"/>
                    </VBox>

                </VBox>
            </ScrollPane>
        </center>
    </BorderPane>

    <!-- ══════════════════════════════════════════════════════════
         VISTA 2 – TABLA COMPLETA DE INVENTARIO
    ══════════════════════════════════════════════════════════ -->
    <BorderPane fx:id="vistaTabla" visible="false" managed="false">

        <top>
            <VBox>
                <HBox styleClass="section-toolbar" spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets topRightBottomLeft="10"/></padding>
                    <Button text="← Regresar" onAction="#onMostrarAgregar"/>
                    <Separator orientation="VERTICAL"/>
                    <Button text="⚠ Solo stock bajo" onAction="#onFiltrarBajos"
                            styleClass="button-danger"/>
                    <Button text="Ver todos"         onAction="#onVerTodos"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="🖨 Imprimir"        onAction="#onReporteInventario"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="0" right="10" bottom="8" left="10"/></padding>
                    <Label text="🔍"/>
                    <TextField fx:id="txtBuscarTabla"
                               promptText="Buscar producto..."
                               HBox.hgrow="ALWAYS"
                               onKeyReleased="#onBuscarEnTabla"/>
                </HBox>
            </VBox>
        </top>

        <center>
            <TableView fx:id="tablaInventario">
                <columns>
                    <TableColumn fx:id="colCodigo"      text="Código"      prefWidth="140"/>
                    <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="280"/>
                    <TableColumn fx:id="colActual"      text="Stock"       prefWidth="80"/>
                    <TableColumn fx:id="colMinimo"      text="Mínimo"      prefWidth="80"/>
                    <TableColumn fx:id="colEstado"      text="Estado"      prefWidth="110"/>
                    <TableColumn fx:id="colDepartamento" text="Departamento" prefWidth="150"/>
                </columns>
                <placeholder>
                    <Label text="No hay productos en inventario."/>
                </placeholder>
            </TableView>
        </center>
    </BorderPane>

    <!-- ══════════════════════════════════════════════════════════
         VISTA 3 – REPORTE DE INVENTARIO
    ══════════════════════════════════════════════════════════ -->
    <BorderPane fx:id="vistaReporte" visible="false" managed="false">

        <top>
            <HBox styleClass="section-toolbar" spacing="8" alignment="CENTER_LEFT">
                <padding><Insets topRightBottomLeft="10"/></padding>
                <Button text="← Regresar" onAction="#onMostrarAgregar"/>
                <Separator orientation="VERTICAL"/>
                <Label text="REPORTE DE INVENTARIO" styleClass="form-section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="🖨 Imprimir / Exportar" onAction="#onReporteInventario"/>
            </HBox>
        </top>

        <center>
            <!-- TODO: contenido del reporte — placeholder -->
            <Label text="📊 Reporte disponible próximamente."
                   style="-fx-font-size:16;-fx-text-fill:-color-fg-muted"
                   alignment="CENTER"/>
        </center>
    </BorderPane>

    <!-- ══════════════════════════════════════════════════════════
         VISTA 4 – HISTORIAL DE MOVIMIENTOS
    ══════════════════════════════════════════════════════════ -->
    <BorderPane fx:id="vistaMovimientos" visible="false" managed="false">

        <top>
            <VBox>
                <HBox styleClass="section-toolbar" spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets topRightBottomLeft="10"/></padding>
                    <Button text="← Regresar" onAction="#onMostrarAgregar"/>
                    <Separator orientation="VERTICAL"/>
                    <Label text="HISTORIAL DE MOVIMIENTOS" styleClass="form-section-title"/>
                </HBox>

                <!-- Filtro de fechas -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <padding><Insets top="4" right="10" bottom="8" left="10"/></padding>
                    <Label text="Desde:"/>
                    <DatePicker fx:id="dateDesde" prefWidth="150"/>
                    <Label text="Hasta:"/>
                    <DatePicker fx:id="dateHasta" prefWidth="150"/>
                    <Button text="Filtrar" onAction="#onFiltrarMovimientos"
                            styleClass="button-success"/>
                    <Button text="Ver hoy" onAction="#onMovimientosHoy"/>
                </HBox>
            </VBox>
        </top>

        <center>
            <TableView fx:id="tablaMovimientos">
                <columns>
                    <TableColumn fx:id="colMovFecha"     text="Fecha"      prefWidth="160"/>
                    <TableColumn fx:id="colMovProducto"  text="Producto"   prefWidth="240"/>
                    <TableColumn fx:id="colMovTipo"      text="Tipo"       prefWidth="110"/>
                    <TableColumn fx:id="colMovCantidad"  text="Cantidad"   prefWidth="90"/>
                    <TableColumn fx:id="colMovAnterior"  text="Antes"      prefWidth="80"/>
                    <TableColumn fx:id="colMovNueva"     text="Después"    prefWidth="80"/>
                    <TableColumn fx:id="colMovUsuario"   text="Usuario"    prefWidth="120"/>
                    <TableColumn fx:id="colMovNota"      text="Nota"       prefWidth="200"/>
                </columns>
                <placeholder>
                    <Label text="Sin movimientos en el período seleccionado."/>
                </placeholder>
            </TableView>
        </center>
    </BorderPane>

    <!-- ══════════════════════════════════════════════════════════
         VISTA 5 – IMPORTAR CSV
    ══════════════════════════════════════════════════════════ -->
    <BorderPane fx:id="vistaImportar" visible="false" managed="false">

        <top>
            <HBox styleClass="section-toolbar" spacing="8" alignment="CENTER_LEFT">
                <padding><Insets topRightBottomLeft="10"/></padding>
                <Button text="← Regresar" onAction="#onMostrarAgregar"/>
                <Separator orientation="VERTICAL"/>
                <Label text="IMPORTAR DESDE CSV" styleClass="form-section-title"/>
            </HBox>
        </top>

        <center>
            <ScrollPane fitToWidth="true">
                <VBox spacing="16" maxWidth="680" alignment="TOP_CENTER">
                    <padding><Insets top="24" right="40" bottom="24" left="40"/></padding>

                    <!-- Instrucciones -->
                    <VBox spacing="6"
                          style="-fx-background-color:-color-bg-subtle;
                                 -fx-background-radius:8;-fx-padding:14;">
                        <Label text="Formato esperado del CSV:" styleClass="field-label"/>
                        <Label text="Codigo | Descripcion | Precio Costo | Precio Venta | Precio Mayoreo | Inventario | Inv. Minimo | Departamento"
                               wrapText="true"
                               style="-fx-font-family:monospace;-fx-font-size:11;
                                      -fx-text-fill:-color-fg-muted"/>
                        <Label text="• La primera fila debe ser el encabezado."
                               style="-fx-font-size:11"/>
                        <Label text="• Si el producto ya existe (mismo código), se actualiza su precio y stock."
                               style="-fx-font-size:11"/>
                        <Label text="• Departamentos nuevos se crean automáticamente."
                               style="-fx-font-size:11"/>
                    </VBox>

                    <!-- Selección de archivo -->
                    <VBox spacing="6">
                        <Label text="Archivo CSV" styleClass="field-label"/>
                        <HBox spacing="8">
                            <TextField fx:id="txtRutaArchivo"
                                       promptText="Selecciona un archivo .csv o .txt"
                                       HBox.hgrow="ALWAYS" editable="false"/>
                            <Button text="📂 Elegir archivo..."
                                    onAction="#onElegirArchivo"/>
                        </HBox>
                    </VBox>

                    <!-- Opciones de importación -->
                    <VBox spacing="6">
                        <Label text="Opciones" styleClass="field-label"/>
                        <CheckBox fx:id="chkActualizarExistentes"
                                  text="Actualizar productos que ya existen (precios y stock)"
                                  selected="true"/>
                        <CheckBox fx:id="chkCrearDepartamentos"
                                  text="Crear departamentos nuevos automáticamente"
                                  selected="true"/>
                    </VBox>

                    <!-- Barra de progreso (oculta hasta importar) -->
                    <VBox fx:id="panelProgreso"
                          visible="false" managed="false" spacing="6">
                        <Label fx:id="lblProgreso" text="Procesando..."/>
                        <ProgressBar fx:id="progressBar" maxWidth="Infinity" progress="0"/>
                    </VBox>

                    <!-- Log de resultados -->
                    <VBox fx:id="panelResultado"
                          visible="false" managed="false" spacing="6">
                        <Label text="Resultado:" styleClass="field-label"/>
                        <TextArea fx:id="txtLog" editable="false"
                                  prefRowCount="8" wrapText="true"
                                  style="-fx-font-family:monospace;-fx-font-size:11"/>
                    </VBox>

                    <HBox spacing="10">
                        <Button fx:id="btnImportar"
                                text="📥 Iniciar Importación"
                                onAction="#onEjecutarImportacion"
                                styleClass="button-success"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                prefHeight="38"/>
                    </HBox>

                </VBox>
            </ScrollPane>
        </center>
    </BorderPane>

</StackPane>
