<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!--
    productos.fxml  –  Catálogo de Productos (F3)
    Controlador: ProductosController.java

    Dos vistas que se intercambian a pantalla completa:
    ┌────────────────────────────────────────────────┐
    │  VISTA A – Tabla  (visible por defecto)        │
    │  toolbar + búsqueda + TableView                │
    └────────────────────────────────────────────────┘
    ┌────────────────────────────────────────────────┐
    │  VISTA B – Formulario  (visible al pulsar      │
    │  Nuevo / Modificar, ocupa TODO el espacio)     │
    └────────────────────────────────────────────────┘
-->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="me.eliassanchezfernandez.puntodeventa.controller.ProductosController">

    <!-- ══════════════════════════════════════════════════════════════
         VISTA A – TABLA DE PRODUCTOS
    ══════════════════════════════════════════════════════════════ -->
    <BorderPane fx:id="vistaTabla">

        <!-- Toolbar + búsqueda -->
        <top>
            <VBox>

                <HBox styleClass="section-toolbar" spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets topRightBottomLeft="10"/></padding>
                    <Button fx:id="btnNuevo"      text="+ Nuevo"
                            onAction="#onNuevo"   styleClass="button-success"/>
                    <Button fx:id="btnModificar"  text="✏ Modificar"
                            onAction="#onModificar"/>
                    <Button fx:id="btnEliminar"   text="🗑 Eliminar"
                            onAction="#onEliminar" styleClass="button-danger"/>
                    <Separator orientation="VERTICAL"/>
                    <Button text="Departamentos"      onAction="#onDepartamentos"/>
                    <Button text="Ventas por Período" onAction="#onVentasPeriodo"/>
                    <Button text="⭐ Promociones"      onAction="#onPromociones"/>
                    <Button text="📥 Importar"         onAction="#onImportar"/>
                </HBox>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="0" right="10" bottom="8" left="10"/></padding>
                    <Label text="🔍"/>
                    <TextField fx:id="txtBuscar"
                               promptText="Buscar por código o descripción..."
                               HBox.hgrow="ALWAYS"
                               onKeyReleased="#onBuscar"/>
                </HBox>
            </VBox>
        </top>

        <!-- Tabla -->
        <center>
            <TableView fx:id="tablaProductos"
                       onMouseClicked="#onTablaDobleClick">
                <columns>
                    <TableColumn fx:id="colCodigo"       text="Código"       prefWidth="140"/>
                    <TableColumn fx:id="colDescripcion"  text="Descripción"  prefWidth="260"/>
                    <TableColumn fx:id="colPrecioCosto"  text="Costo"        prefWidth="85"/>
                    <TableColumn fx:id="colPrecioVenta"  text="Venta"        prefWidth="85"/>
                    <TableColumn fx:id="colPrecioMayor"  text="Mayoreo"      prefWidth="85"/>
                    <TableColumn fx:id="colExistencia"   text="Stock"        prefWidth="75"/>
                    <TableColumn fx:id="colDepartamento" text="Departamento" prefWidth="140"/>
                </columns>
                <placeholder>
                    <Label text="No hay productos registrados. Pulsa + Nuevo para agregar."/>
                </placeholder>
            </TableView>
        </center>

    </BorderPane>

    <!-- ══════════════════════════════════════════════════════════════
         VISTA B – FORMULARIO  (oculta por defecto)
    ══════════════════════════════════════════════════════════════ -->

    <BorderPane fx:id="vistaFormulario" visible="false" managed="false">
        <!-- Cabecera del formulario -->
        <top>
            <HBox styleClass="section-toolbar" spacing="8" alignment="CENTER_LEFT">
                <padding><Insets topRightBottomLeft="10"/></padding>
                <Button text="← Regresar"
                        onAction="#onCancelarFormulario"/>
                <Separator orientation="VERTICAL"/>
                <Label fx:id="lblTituloForm" text="NUEVO PRODUCTO"
                       styleClass="form-section-title"/>
            </HBox>
        </top>

        <!-- Contenido del formulario centrado y con scroll -->
        <center>
            <ScrollPane fitToWidth="true">
                <VBox styleClass="form-panel" spacing="14"
                      maxWidth="680" alignment="TOP_CENTER">
                    <padding><Insets top="24" right="40" bottom="32" left="40"/></padding>

                    <!-- ── CÓDIGO DE BARRAS ─────────────────────── -->
                    <VBox spacing="4">
                        <Label text="Código de Barras *" styleClass="field-label"/>
                        <TextField fx:id="txtCodigoBarras"
                                   promptText="Escanea o escribe el código"
                                   onKeyReleased="#onCodigoBarrasChanged"/>
                        <HBox fx:id="hboxYaExiste"
                              visible="false" managed="false"
                              spacing="6" alignment="CENTER_LEFT"
                              style="-fx-background-color:rgba(220,53,69,0.12);-fx-background-radius:6;-fx-padding:8;">
                            <Label text="⚠"
                                   style="-fx-text-fill:#C0392B;-fx-font-size:14"/>
                            <VBox spacing="1">
                                <Label text="Este código ya está registrado."
                                       style="-fx-text-fill:#C0392B;-fx-font-weight:bold;-fx-font-size:12"/>
                                <Label fx:id="lblProductoExistente" text=""
                                       style="-fx-text-fill:#C0392B;-fx-font-size:11"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- ── DESCRIPCIÓN ─────────────────────────── -->
                    <VBox spacing="4">
                        <Label text="Descripción *" styleClass="field-label"/>
                        <TextField fx:id="txtDescripcion"
                                   promptText="Nombre del producto"/>
                    </VBox>

                    <!-- ── TIPO DE VENTA ───────────────────────── -->
                    <VBox spacing="6">
                        <Label text="Se vende" styleClass="field-label"/>
                        <RadioButton fx:id="rbUnidad"
                                     text="Por Unidad / Pieza"
                                     selected="true">
                            <toggleGroup>
                                <ToggleGroup fx:id="toggleTipoVenta"/>
                            </toggleGroup>
                        </RadioButton>
                        <RadioButton fx:id="rbGranel"
                                     text="A Granel  (usa decimales)"
                                     toggleGroup="$toggleTipoVenta"/>
                        <RadioButton fx:id="rbPaquete"
                                     text="Como Paquete (kit)"
                                     toggleGroup="$toggleTipoVenta"/>
                    </VBox>

                    <Separator/>

                    <!-- ── PRECIOS ─────────────────────────────── -->
                    <Label text="Precios" styleClass="form-subsection-title"/>

                    <GridPane hgap="16" vgap="10">
                        <Label text="Precio Costo *"
                               GridPane.columnIndex="0" GridPane.rowIndex="0"
                               styleClass="field-label"/>
                        <TextField fx:id="txtPrecioCosto" promptText="0.00"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"
                                   onKeyReleased="#onValidarPrecio"/>

                        <Label text="Precio Venta *"
                               GridPane.columnIndex="0" GridPane.rowIndex="1"
                               styleClass="field-label"/>
                        <TextField fx:id="txtPrecioVenta" promptText="0.00"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"
                                   onKeyReleased="#onValidarPrecio"/>

                        <Label text="Precio Mayoreo"
                               GridPane.columnIndex="0" GridPane.rowIndex="2"
                               styleClass="field-label"/>
                        <TextField fx:id="txtPrecioMayoreo" promptText="0.00"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2"
                                   onKeyReleased="#onValidarPrecio"/>

                        <columnConstraints>
                            <ColumnConstraints prefWidth="160" minWidth="140"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                    </GridPane>

                    <Label fx:id="lblErrorPrecio"
                           text="⚠ Los precios no pueden ser negativos."
                           visible="false" managed="false"
                           style="-fx-text-fill:#C0392B;-fx-font-size:11"/>

                    <Separator/>

                    <!-- ── DEPARTAMENTO ────────────────────────── -->
                    <VBox spacing="4">
                        <Label text="Departamento" styleClass="field-label"/>
                        <ComboBox fx:id="comboDepartamento"
                                  promptText="— Sin Departamento —"
                                  maxWidth="Infinity"/>
                    </VBox>

                    <Separator/>

                    <!-- ── INVENTARIO ──────────────────────────── -->
                    <Label text="Inventario" styleClass="form-subsection-title"/>

                    <CheckBox fx:id="chkUsaInventario"
                              text="Este producto SÍ utiliza inventario"
                              selected="true"
                              onAction="#onToggleInventario"/>

                    <GridPane fx:id="gridInventario" hgap="16" vgap="10">
                        <Label text="Cantidad Actual"
                               GridPane.columnIndex="0" GridPane.rowIndex="0"
                               styleClass="field-label"/>
                        <TextField fx:id="txtCantidadActual" promptText="0"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"
                                   onKeyReleased="#onValidarInventario"/>

                        <Label text="Cantidad Mínima"
                               GridPane.columnIndex="0" GridPane.rowIndex="1"
                               styleClass="field-label"/>
                        <TextField fx:id="txtCantidadMinima" promptText="0"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"
                                   onKeyReleased="#onValidarInventario"/>

                        <Label text="(Alerta cuando el stock llegue a este valor)"
                               style="-fx-text-fill:-color-fg-muted;-fx-font-size:10"
                               GridPane.columnIndex="0" GridPane.rowIndex="2"
                               GridPane.columnSpan="2"/>

                        <columnConstraints>
                            <ColumnConstraints prefWidth="160" minWidth="140"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                    </GridPane>

                    <Label fx:id="lblErrorInventario"
                           text="⚠ Las cantidades no pueden ser negativas."
                           visible="false" managed="false"
                           style="-fx-text-fill:#C0392B;-fx-font-size:11"/>

                    <Region minHeight="12"/>

                    <!-- ── BOTONES FINALES ─────────────────────── -->
                    <HBox spacing="12">
                        <Button fx:id="btnGuardar"
                                text="✅ Guardar Producto"
                                onAction="#onGuardarProducto"
                                styleClass="button-success"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                prefHeight="38"/>
                        <Button fx:id="btnCancelarForm"
                                text="✖ Cancelar"
                                onAction="#onCancelarFormulario"
                                styleClass="button-danger"
                                prefHeight="38"/>
                    </HBox>

                </VBox>
            </ScrollPane>
        </center>

    </BorderPane>

       <!-- vista de departamentos  (ocualta ) -->

    <BorderPane fx:id="vistaDepartamentos"   visible="false" managed="false">

        <!-- Cabecera de la ventana -->
        <top>
            <HBox styleClass="section-toolbar" spacing="8" alignment="CENTER_LEFT">
                <padding><Insets topRightBottomLeft="10"/></padding>
                <Button text="← Regresar"
                        onAction="#onCancelarDepartamento"/>
                <Separator orientation="VERTICAL"/>
                <!-- Titulo de la ventana -->
                <Label  text="Departamentos"
                       styleClass="form-section-title"/>
            </HBox>
        </top>

        <!-- Contenido de la ventana deividido ?  -->
        <center>

        <SplitPane dividerPositions="0.4">

            <VBox spacing="8">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="0" right="10" bottom="8" left="10"/></padding>

                    <Label text="🔍"/>

                    <TextField fx:id="txtBuscarDepartamento"
                               promptText="Buscar departamento..."
                               HBox.hgrow="ALWAYS"
                               onKeyReleased="#onBuscarDepartamento"/>
                </HBox>

                    <TableView fx:id="tablaDepartamentos"

                            onMouseClicked="#onTablaDobleClick">
                    <columns>
                        <TableColumn fx:id="colNombreDepartamento"       text="Nombre"       prefWidth="140"/>
                    </columns>

                    <placeholder>
                        <Label text="No hay Departamentos registrados. intente registrar un nuevo Departamento."/>
                    </placeholder>

                </TableView>    
            </VBox>

            <VBox>
            
                <HBox styleClass="section-toolbar" spacing="8" alignment="CENTER_LEFT">

                    <padding><Insets topRightBottomLeft="10"/></padding>

                    <Button fx:id="btnNuevoDepartamento"      text="+ Nuevo Departamento"
                            onAction="#onNuevoDepartamento"   styleClass="button-success"/>

             
                    <Button fx:id="btnEliminarDepartamento"   text="🗑 Eliminar"
                            onAction="#onEliminarDepartamento" styleClass="button-danger"/>
                    
                </HBox>

                    <Separator orientation="VERTICAL"/>
    
                    <Label text="DETALLES DEL DEPARTAMENTO" styleClass="form-section-title">
                        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding> 
                    </Label>
    
    
                    <Label text="Nombre del Departamento:" styleClass="field-label">
                        <padding><Insets top="10" right="10" bottom="0" left="10"/></padding>
                    </Label>
                    <TextField fx:id="txtNombreDepartamento" promptText="Escribe el nombre del departamento"
                                onKeyReleased="#onValidarDepartamento" HBox.hgrow="ALWAYS">
                        <padding><Insets top="0" right="10" bottom="10" left="10"/></padding>
                    </TextField>
    
                    <Label fx:id="lblErrorDepartamento"
                            text="⚠ El nombre no puede estar vacío."
                            visible="false" managed="false"
                            style="-fx-text-fill:#C0392B;-fx-font-size:11">
                        <padding><Insets top="0" right="10" bottom="10" left="10"/></padding>
                    </Label>

                <HBox styleClass="section-toolbar" spacing="8" alignment="CENTER_LEFT">

                    <padding><Insets topRightBottomLeft="10"/></padding>

                    <Button fx:id="btnGuardarDepartamento"      text="+ Guardar Departamento"
                            onAction="#onGuardarDepartamento"   styleClass="button-success"/>

                    <Button fx:id="btnCancelarDepartamento"   text="✖ Cancelar"
                            onAction="#onCancelarDepartamento" styleClass="button-danger"/>
                </HBox>
            
            </VBox>
            
        </SplitPane>

        </center>

    </BorderPane>

</StackPane>
